# ─────────────────────────────────────────────────────────────────────────────
# .env.example — BilliardsLadder environment variables
#
# Copy to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env to git. It is already in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Server ──────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ─── Database (Neon PostgreSQL) ───────────────────────────────────────────────
# Get from: Neon dashboard → your project → Connection Details → Connection string
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ─── Session ──────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
SESSION_SECRET=replace-with-a-long-random-string

# ─── Replit Auth (OIDC) ───────────────────────────────────────────────────────
# Set automatically by Replit. Only needed for local dev:
REPLIT_DOMAINS=your-app.username.repl.co
REPL_ID=your-repl-id
# ISSUER_URL is optional — defaults to https://replit.com/oidc if not set
# ISSUER_URL=https://replit.com/oidc

# ─── Stripe ───────────────────────────────────────────────────────────────────
# Get from: Stripe Dashboard → Developers → API keys
STRIPE_SECRET_KEY=sk_test_...

# Get from: Stripe Dashboard → Developers → Webhooks → your endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Stripe Player Plan Price IDs ─────────────────────────────────────────────
# Get from: Stripe Dashboard → Products → [plan name] → Prices
# These override the placeholders in shared/config/stripe-prices.ts
STRIPE_PRICE_ROOKIE=price_...
STRIPE_PRICE_STANDARD=price_...
STRIPE_PRICE_PREMIUM=price_...
STRIPE_PRICE_FAMILY=price_...
STRIPE_PRICE_SENIOR=price_...
STRIPE_PRICE_CHILD=price_...
STRIPE_PRICE_TEEN=price_...

# ─── Stripe Operator Plan Price IDs ───────────────────────────────────────────
# Also accepted as SMALL_PRICE_ID etc. (legacy names kept for compatibility)
STRIPE_PRICE_OP_SMALL=price_...
STRIPE_PRICE_OP_MEDIUM=price_...
STRIPE_PRICE_OP_LARGE=price_...
STRIPE_PRICE_OP_MEGA=price_...

# ─── OpenAI (AI Coaching) ─────────────────────────────────────────────────────
# Get from: platform.openai.com → API keys
# Leave blank to disable AI Coaching (FEATURE_FLAGS.AI_COACHING → false)
OPENAI_API_KEY=sk-...

# ─── SendGrid (Email) ─────────────────────────────────────────────────────────
# Get from: app.sendgrid.com → Settings → API Keys
# Leave blank to disable email notifications
SENDGRID_API_KEY=SG...
EMAIL_FROM=noreply@yourdomain.com

# ─── Feature Flag Overrides ───────────────────────────────────────────────────
# Override any flag in server/config/featureFlags.ts without changing code.
# Values: "true" or "false" (string)
# FEATURE_OBJECT_CAROM_GAMES=true
# FEATURE_POOLHALL_MATCHES=true
# FEATURE_GAME_VOTING=true
# FEATURE_SPOT_SHOTS=true
# FEATURE_PREDICTION_MARKET=false
# FEATURE_HALL_BATTLES=true
# FEATURE_LIVE_STREAM=true
# FEATURE_ADMIN_STAFF=true
# FEATURE_ADMIN_OPERATORS=true
